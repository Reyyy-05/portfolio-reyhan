---
// Resume CTA — Download CV section
---

<section class="py-20 md:py-28 relative">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="reveal">
      <div class="bg-surface border border-border rounded-2xl p-8 md:p-12 text-center relative overflow-hidden">
        <!-- Background accent glow -->
        <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_center,_rgba(94,234,212,0.04)_0%,_transparent_70%)]"></div>

        <div class="relative">
          <p class="font-mono text-xs uppercase tracking-[0.2em] text-accent mb-3">// Resume</p>
          <h2 class="text-2xl md:text-4xl font-semibold tracking-tight text-text font-display mb-4">
            Interested in working together?
          </h2>
          <p class="text-base text-text-muted max-w-xl mx-auto mb-8">
            Download CV saya untuk melihat ringkasan lengkap pengalaman, proyek, dan skill teknis.
          </p>

          <!-- TODO: Pastikan file cv-reyhan.pdf sudah dimasukkan ke folder public/ -->
          <a
            href="/cv-reyhan.pdf"
            id="resume-download"
            class="inline-flex items-center gap-2 bg-accent text-bg font-medium px-6 py-3 rounded-lg hover:bg-accent/90 transition-colors"
          >
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
            </svg>
            Download Resume
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
