---
// Resume CTA — Download CV section
---

<section class="section-spacing relative bg-bg">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="reveal">
      <div class="editorial-card card-teal-glow p-8 md:p-14 text-center relative overflow-hidden border border-border/80 bg-surface/30">
        <!-- Background accent glow -->
        <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_center,_rgba(94,234,212,0.03)_0%,_transparent_70%)]"></div>

        <div class="relative max-w-xl mx-auto space-y-6">
          <p class="font-mono text-xs uppercase tracking-[0.25em] text-accent">/ CURRICULUM VITAE</p>
          <h2 class="text-3xl md:text-5xl font-bold tracking-tighter uppercase font-display text-text">
            Looking for a builder?
          </h2>
          <p class="text-base text-text-muted leading-relaxed font-light">
            Download my resume to view a consolidated summary of my education, digital project builds, and technical proficiency.
          </p>

          <div class="pt-4">
            <a
              href="/cv-reyhan.pdf"
              id="resume-download"
              class="inline-flex items-center gap-2 bg-accent text-bg font-medium px-6 py-3 rounded-xl hover:bg-accent/90 transition-all duration-300 shadow-sm hover:shadow-[0_8px_20px_-6px_rgba(94,234,212,0.3)] text-sm"
            >
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
              </svg>
              Download Resume (PDF)
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
