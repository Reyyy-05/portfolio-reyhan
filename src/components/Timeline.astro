---
import { timelineMilestones } from '../data/experience';
---

<section id="journey" class="py-20 md:py-28 relative bg-bg-alt">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Section Header -->
    <div class="mb-12 md:mb-16 reveal">
      <p class="font-mono text-xs uppercase tracking-[0.2em] text-accent mb-3">// Journey</p>
      <h2 class="text-3xl md:text-5xl font-semibold tracking-tight text-text font-display">
        Build Timeline
      </h2>
      <p class="text-base text-text-muted mt-4 max-w-2xl">
        Milestone perjalanan belajar dan membangun produk digital.
      </p>
    </div>

    <!-- Timeline -->
    <div class="relative">
      <!-- Vertical Line -->
      <div class="absolute left-4 md:left-6 top-0 bottom-0 w-px bg-border"></div>

      <div class="space-y-8 reveal-stagger">
        {timelineMilestones.map((milestone, index) => (
          <div class="relative pl-12 md:pl-16 reveal">
            <!-- Dot -->
            <div class="absolute left-2.5 md:left-4.5 top-1.5 w-3 h-3 rounded-full bg-accent/20 border-2 border-accent">
              <div class="absolute inset-0.5 rounded-full bg-accent animate-pulse-dot"></div>
            </div>

            <!-- Content -->
            <div class="bg-surface border border-border rounded-xl p-5 transition-all duration-300 hover:border-border-strong">
              <div class="flex items-center gap-2 mb-2">
                <span class="font-mono text-[10px] text-text-dim uppercase tracking-wider">
                  Phase {String(index + 1).padStart(2, '0')}
                </span>
              </div>
              <h3 class="text-base md:text-lg font-medium text-text mb-2">{milestone.title}</h3>
              <p class="text-sm text-text-dim leading-relaxed mb-3">{milestone.description}</p>
              <div class="flex flex-wrap gap-1.5">
                {milestone.tags.map((tag) => (
                  <span class="font-mono text-[9px] text-accent/70 bg-accent/5 border border-accent/10 rounded px-2 py-0.5">
                    {tag}
                  </span>
                ))}
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
