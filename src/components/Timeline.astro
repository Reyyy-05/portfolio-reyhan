---
import { timelineMilestones } from '../data/experience';
---

<section id="journey" class="section-spacing relative bg-bg">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Section Header -->
    <div class="mb-16 md:mb-20 reveal">
      <p class="font-mono text-xs uppercase tracking-[0.25em] text-accent mb-3">/ EVOLUTION</p>
      <h2 class="text-4xl md:text-6xl font-bold tracking-tighter uppercase leading-[0.95] font-display text-text">
        BUILD TIMELINE
      </h2>
      <p class="text-base text-text-muted mt-4 max-w-2xl font-light">
        A chronicle of educational milestones, skill acquisitions, and key digital product builds.
      </p>
    </div>

    <!-- Timeline Layout -->
    <div class="relative">
      <!-- Vertical Line -->
      <div class="absolute left-4 md:left-6 top-0 bottom-0 w-px bg-border/60"></div>

      <div class="space-y-8 reveal-stagger">
        {timelineMilestones.map((milestone, index) => (
          <div class="relative pl-12 md:pl-16 reveal">
            <!-- Pulse Dot indicator -->
            <div class="absolute left-2.5 md:left-4.5 top-2.5 w-3 h-3 rounded-full bg-accent/20 border border-accent">
              <div class="absolute inset-0.5 rounded-full bg-accent animate-pulse-dot"></div>
            </div>

            <!-- Content Card -->
            <div class="editorial-card card-teal-glow border border-border/80 bg-surface/40 p-6 md:p-8">
              <div class="flex items-center gap-2 mb-2 font-mono text-[9px] text-text-dim uppercase tracking-wider">
                <span>Phase {String(index + 1).padStart(2, '0')}</span>
              </div>
              <h3 class="text-lg font-medium text-text mb-2">{milestone.title}</h3>
              <p class="text-sm text-text-muted font-light leading-relaxed mb-4">{milestone.description}</p>
              <div class="flex flex-wrap gap-1.5 pt-2 border-t border-border/20">
                {milestone.tags.map((tag) => (
                  <span class="font-mono text-[9px] text-accent bg-accent/5 border border-accent/15 rounded px-2 py-0.5">
                    {tag}
                  </span>
                ))}
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
