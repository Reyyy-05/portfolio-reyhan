---
const currentYear = new Date().getFullYear();
const navLinks = [
  { label: 'Work', href: '#work' },
  { label: 'About', href: '#about' },
  { label: 'Capabilities', href: '#capabilities' },
  { label: 'Contact', href: '#contact' },
];
---

<footer class="pt-24 pb-12 border-t border-border/40 bg-bg relative overflow-hidden">
  <!-- Giant Background Text (Low contrast, non-distracting) -->
  <div class="absolute inset-x-0 -bottom-8 pointer-events-none select-none text-center leading-none font-bold text-[10vw] md:text-[13vw] tracking-tighter uppercase text-surface-hover/30 font-display opacity-40 z-0">
    REYHAN
  </div>

  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    <div class="grid grid-cols-1 md:grid-cols-12 gap-10 pb-16">
      
      <!-- Left Column - Brand Info (6 cols on md) -->
      <div class="md:col-span-6 space-y-4">
        <a
          href="#"
          class="font-mono text-sm tracking-wider text-accent hover:text-accent/80 transition-colors"
          aria-label="Go to top"
        >
          raf<span class="text-text-dim">.</span>build
        </a>
        <p class="text-sm font-semibold text-text">
          Reyhan Albar Fahryan
        </p>
        <p class="text-xs text-text-dim leading-relaxed max-w-sm font-light">
          Informatics Student & Digital Product Builder. Building web systems, mobile app prototypes, and data integrity validations.
        </p>
      </div>

      <!-- Center Column - Directory (3 cols on md) -->
      <div class="md:col-span-3 space-y-4">
        <p class="font-mono text-[10px] uppercase tracking-wider text-text-dim">/ DIRECTORY</p>
        <ul class="space-y-2 text-xs">
          {navLinks.map((link) => (
            <li>
              <a
                href={link.href}
                class="text-text-muted hover:text-accent transition-colors duration-200"
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Right Column - External Resources (3 cols on md) -->
      <div class="md:col-span-3 space-y-4">
        <p class="font-mono text-[10px] uppercase tracking-wider text-text-dim">/ EXTERNAL</p>
        <ul class="space-y-2 text-xs">
          <li>
            <a
              href="https://github.com/Reyyy-05"
              target="_blank"
              rel="noopener noreferrer"
              class="text-text-muted hover:text-accent transition-colors duration-200"
            >
              GitHub Portfolio
            </a>
          </li>
          <li>
            <a
              href="mailto:rayhanalbar75@gmail.com"
              class="text-text-muted hover:text-accent transition-colors duration-200"
            >
              Direct Email
            </a>
          </li>
        </ul>
      </div>
    </div>

    <!-- Bottom copyright row -->
    <div class="flex flex-col sm:flex-row items-center justify-between gap-4 pt-8 border-t border-border/20 text-[10px] text-text-dim font-mono">
      <div>
        &copy; {currentYear} Reyhan Albar Fahryan. All rights reserved.
      </div>
      <div class="flex items-center gap-2">
        <span>Built with Astro & Tailwind</span>
        <span>•</span>
        <span>Build Log concept</span>
      </div>
    </div>
  </div>
</footer>
