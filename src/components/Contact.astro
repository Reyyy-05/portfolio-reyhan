---
// Contact section
---

<section id="contact" class="section-spacing relative bg-bg-alt/50 border-t border-border/40">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid lg:grid-cols-12 gap-12 lg:gap-16 items-start">

      <!-- Left Column - Headline & Social badges -->
      <div class="lg:col-span-6 reveal space-y-8 text-left">
        <div class="space-y-6">
          <p class="font-mono text-xs uppercase tracking-[0.25em] text-accent">/ INQUIRIES</p>
          <h2 class="text-4xl md:text-6xl font-bold tracking-tighter uppercase leading-[0.95] font-display text-text">
            Let’s build<br />something useful.
          </h2>
          <p class="text-base text-text-muted leading-relaxed font-light max-w-md">
            Open for internship opportunities, collaboration, and digital project discussions. Feel free to reach out.
          </p>
        </div>

        <!-- Social Badges Row (GitHub only since LinkedIn is hidden) -->
        <div class="flex items-center gap-3 pt-2">
          <a
            href="https://github.com/Reyyy-05"
            target="_blank"
            rel="noopener noreferrer"
            class="w-10 h-10 flex items-center justify-center rounded-full border border-border bg-surface/40 text-text-muted hover:text-accent hover:border-accent hover:-translate-y-0.5 transition-all duration-300"
            aria-label="GitHub Profile"
          >
            <svg class="w-4.5 h-4.5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- Right Column — Contact Cards -->
      <div class="lg:col-span-6 space-y-4 reveal w-full">
        <!-- GitHub Card -->
        <a
          href="https://github.com/Reyyy-05"
          target="_blank"
          rel="noopener noreferrer"
          id="contact-github"
          class="editorial-card card-teal-glow flex items-center gap-4 p-5 border border-border/80 bg-surface/50 transition-all duration-300 group"
        >
          <div class="w-10 h-10 flex items-center justify-center bg-accent/5 border border-accent/15 rounded-xl text-accent group-hover:bg-accent/15 transition-colors">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
            </svg>
          </div>
          <div>
            <p class="text-sm font-medium text-text group-hover:text-accent transition-colors">GitHub Profile</p>
            <p class="text-xs text-text-dim font-mono">github.com/Reyyy-05</p>
          </div>
          <svg class="w-4 h-4 text-text-dim ml-auto group-hover:text-accent group-hover:translate-x-1 transition-all duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 5l7 7-7 7" />
          </svg>
        </a>

        <!-- Email Card -->
        <a
          href="mailto:rayhanalbar75@gmail.com"
          id="contact-email"
          class="editorial-card card-teal-glow flex items-center gap-4 p-5 border border-border/80 bg-surface/50 transition-all duration-300 group"
        >
          <div class="w-10 h-10 flex items-center justify-center bg-accent/5 border border-accent/15 rounded-xl text-accent group-hover:bg-accent/15 transition-colors">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
          </div>
          <div>
            <p class="text-sm font-medium text-text group-hover:text-accent transition-colors">Direct Email</p>
            <p class="text-xs text-text-dim font-mono">rayhanalbar75@gmail.com</p>
          </div>
          <svg class="w-4 h-4 text-text-dim ml-auto group-hover:text-accent group-hover:translate-x-1 transition-all duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 5l7 7-7 7" />
          </svg>
        </a>
      </div>

    </div>
  </div>
</section>
