---
// Contact section
---

<section id="contact" class="section-spacing relative bg-bg-alt/50 border-t border-border/40">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid lg:grid-cols-12 gap-12 lg:gap-16 items-center">

      <!-- Left Column - Headline -->
      <div class="lg:col-span-6 reveal space-y-6">
        <p class="font-mono text-xs uppercase tracking-[0.25em] text-accent">/ INQUIRIES</p>
        <h2 class="text-4xl md:text-6xl font-bold tracking-tighter uppercase leading-[0.95] font-display text-text">
          Let’s build<br />something useful.
        </h2>
        <p class="text-base text-text-muted leading-relaxed font-light max-w-md">
          Open for internship opportunities, collaboration, and digital project discussions. Feel free to reach out.
        </p>
      </div>

      <!-- Right Column — Contact Links (Grid of cards) -->
      <div class="lg:col-span-6 space-y-4 reveal">
        <!-- GitHub -->
        <a
          href="https://github.com/Reyyy-05"
          target="_blank"
          rel="noopener noreferrer"
          id="contact-github"
          class="editorial-card card-teal-glow flex items-center gap-4 p-5 border border-border/80 bg-surface/50 transition-all duration-300 group"
        >
          <div class="w-10 h-10 flex items-center justify-center bg-accent/5 border border-accent/15 rounded-xl text-accent group-hover:bg-accent/15 transition-colors">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
            </svg>
          </div>
          <div>
            <p class="text-sm font-medium text-text group-hover:text-accent transition-colors">GitHub Profile</p>
            <p class="text-xs text-text-dim font-mono">github.com/Reyyy-05</p>
          </div>
          <svg class="w-4 h-4 text-text-dim ml-auto group-hover:text-accent group-hover:translate-x-1 transition-all duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 5l7 7-7 7" />
          </svg>
        </a>

        <!-- Email -->
        <a
          href="mailto:contact@reyhan.dev"
          id="contact-email"
          class="editorial-card card-teal-glow flex items-center gap-4 p-5 border border-border/80 bg-surface/50 transition-all duration-300 group"
        >
          <div class="w-10 h-10 flex items-center justify-center bg-accent/5 border border-accent/15 rounded-xl text-accent group-hover:bg-accent/15 transition-colors">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
          </div>
          <div>
            <p class="text-sm font-medium text-text group-hover:text-accent transition-colors">Direct Email</p>
            <p class="text-xs text-text-dim font-mono">contact@reyhan.dev</p>
          </div>
          <svg class="w-4 h-4 text-text-dim ml-auto group-hover:text-accent group-hover:translate-x-1 transition-all duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 5l7 7-7 7" />
          </svg>
        </a>

        <!-- LinkedIn -->
        <a
          href="https://linkedin.com/in/"
          target="_blank"
          rel="noopener noreferrer"
          id="contact-linkedin"
          class="editorial-card card-blue-glow flex items-center gap-4 p-5 border border-border/80 bg-surface/50 transition-all duration-300 group"
        >
          <div class="w-10 h-10 flex items-center justify-center bg-accent-secondary/5 border border-accent-secondary/15 rounded-xl text-accent-secondary group-hover:bg-accent-secondary/15 transition-colors">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
            </svg>
          </div>
          <div>
            <p class="text-sm font-medium text-text group-hover:text-accent-secondary transition-colors">LinkedIn Link</p>
            <p class="text-xs text-text-dim font-mono">Connect with me</p>
          </div>
          <svg class="w-4 h-4 text-text-dim ml-auto group-hover:text-accent-secondary group-hover:translate-x-1 transition-all duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 5l7 7-7 7" />
          </svg>
        </a>
      </div>

    </div>
  </div>
</section>
