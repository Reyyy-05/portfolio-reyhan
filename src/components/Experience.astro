---
import { experiences } from '../data/experience';

const typeLabels: Record<string, string> = {
  internship: 'Internship',
  project: 'Project',
  field: 'Field Work',
  hackathon: 'Hackathon',
  organization: 'Organization',
};

const typeBadgeColors: Record<string, string> = {
  internship: 'text-success bg-success/5 border-success/15',
  project: 'text-accent bg-accent/5 border-accent/15',
  field: 'text-accent-secondary bg-accent-secondary/5 border-accent-secondary/15',
  hackathon: 'text-accent bg-accent/5 border-accent/15',
  organization: 'text-text-muted bg-text-muted/5 border-text-muted/15',
};
---

<section class="section-spacing relative bg-bg-alt/30">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Section Header -->
    <div class="mb-16 md:mb-20 reveal">
      <p class="font-mono text-xs uppercase tracking-[0.25em] text-accent mb-3">/ CHRONOLOGY</p>
      <h2 class="text-4xl md:text-6xl font-bold tracking-tighter uppercase leading-[0.95] font-display text-text">
        EXPERIENCE
      </h2>
    </div>

    <!-- Experience List -->
    <div class="space-y-4 reveal-stagger">
      {experiences.map((exp) => (
        <div class="editorial-card card-blue-glow border border-border/80 bg-surface/40 p-6 md:p-8 reveal">
          <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-4 mb-4">
            <div>
              <h3 class="text-lg font-medium text-text">{exp.role}</h3>
              <p class="text-xs text-text-muted font-mono uppercase tracking-wider mt-1">{exp.organization}</p>
            </div>
            <div class="flex items-center gap-2.5 shrink-0 self-start sm:self-auto">
              <span class:list={['font-mono text-[9px] uppercase tracking-wider border rounded px-2 py-0.5', typeBadgeColors[exp.type]]}>
                {typeLabels[exp.type]}
              </span>
              <span class="font-mono text-xs text-text-dim">{exp.period}</span>
            </div>
          </div>
          <p class="text-sm text-text-muted font-light leading-relaxed">{exp.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
