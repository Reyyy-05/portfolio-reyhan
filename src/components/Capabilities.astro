---
// Capabilities Component - Replaces raw Skills section
const capabilities = [
  {
    index: '01',
    title: 'Web Development',
    description: 'Building optimized, responsive web interfaces and full-stack catalog systems.',
    details: [
      'Interactive product catalogs & directories',
      'High-performance static landing pages',
      'Role-based administrative dashboards'
    ],
    skills: ['Next.js', 'TypeScript', 'Tailwind CSS', 'Astro', 'Node.js', 'GSAP', 'HTML/CSS']
  },
  {
    index: '02',
    title: 'Mobile App Prototyping',
    description: 'Developing mobile client prototypes and application layouts for iOS and Android.',
    details: [
      'Expo React Native framework',
      'Client-side state management (Zustand)',
      'Cross-platform layouts & navigation flows'
    ],
    skills: ['Expo React Native', 'Expo Router', 'Zustand', 'React Native', 'TypeScript']
  },
  {
    index: '03',
    title: 'Data-Oriented Systems',
    description: 'Implementing backend structures focused on data validation, integrity, and provenance.',
    details: [
      'Administrative validation logic',
      'Dataset hash verification & metadata',
      'Relational database integration'
    ],
    skills: ['Prisma ORM', 'Supabase', 'PostgreSQL', 'SQLite', 'Python', 'SQL', 'Firebase']
  },
  {
    index: '04',
    title: 'Product Thinking',
    description: 'Structuring project requirements, workflows, and implementation paths.',
    details: [
      'Early-stage MVP planning & sizing',
      'Technical documentation & READMEs',
      'User flows and schema architecture'
    ],
    skills: ['Git & GitHub', 'Vercel', 'Technical Writing', 'PRD', 'Figma']
  }
];
---

<section id="capabilities" class="section-spacing relative">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Section Header -->
    <div class="mb-16 md:mb-20 reveal">
      <p class="font-mono text-xs uppercase tracking-[0.25em] text-accent mb-3">/ COMPETENCE</p>
      <h2 class="text-4xl md:text-6xl font-bold tracking-tighter uppercase leading-[0.95] font-display text-text">
        CAPABILITIES
      </h2>
      <p class="text-base text-text-muted mt-4 max-w-2xl font-light">
        A structured overview of technical domains and tools I apply to translate ideas into operational digital products.
      </p>
    </div>

    <!-- Capabilities Grid -->
    <div class="grid md:grid-cols-2 gap-6 reveal-stagger">
      {capabilities.map((cap) => (
        <div class="editorial-card card-teal-glow p-6 md:p-8 flex flex-col justify-between border border-border/80 bg-surface/50">
          <div class="space-y-6">
            <!-- Header -->
            <div class="flex items-center justify-between">
              <span class="font-mono text-xs text-accent uppercase tracking-wider">
                / {cap.title}
              </span>
              <span class="font-mono text-xs text-text-dim">
                {cap.index}
              </span>
            </div>

            <!-- Content -->
            <div class="space-y-4">
              <p class="text-base text-text-muted leading-relaxed font-light">
                {cap.description}
              </p>

              <!-- Details Bullet List -->
              <ul class="space-y-2 text-xs text-text-dim pl-1">
                {cap.details.map((detail) => (
                  <li class="flex items-center gap-2">
                    <span class="text-accent/60 text-[8px] font-mono">◈</span>
                    {detail}
                  </li>
                ))}
              </ul>
            </div>
          </div>

          <!-- Bottom: Tech Stack Tags -->
          <div class="mt-8 pt-6 border-t border-border/40">
            <p class="font-mono text-[9px] uppercase tracking-wider text-text-dim mb-3">Associated Stack:</p>
            <div class="flex flex-wrap gap-1.5">
              {cap.skills.map((skill) => (
                <span class="font-mono text-[9px] text-text-muted bg-bg-alt border border-border/50 rounded px-2 py-0.5">
                  {skill}
                </span>
              ))}
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
