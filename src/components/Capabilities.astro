---
// Capabilities Component - Replaces raw Skills section with horizontal editorial list
const capabilities = [
  {
    index: '01',
    title: 'Web Development',
    description: 'Building optimized, responsive web interfaces and full-stack catalog systems.',
    details: [
      'Interactive product catalogs & directories',
      'High-performance static landing pages',
      'Role-based administrative dashboards'
    ],
    skills: ['Next.js', 'TypeScript', 'Tailwind CSS', 'Astro', 'Node.js', 'GSAP', 'HTML/CSS']
  },
  {
    index: '02',
    title: 'Mobile App Prototyping',
    description: 'Developing mobile client prototypes and application layouts for iOS and Android.',
    details: [
      'Expo React Native framework',
      'Client-side state management (Zustand)',
      'Cross-platform layouts & navigation flows'
    ],
    skills: ['Expo React Native', 'Expo Router', 'Zustand', 'React Native', 'TypeScript']
  },
  {
    index: '03',
    title: 'Data-Oriented Systems',
    description: 'Implementing backend structures focused on data validation, integrity, and provenance.',
    details: [
      'Administrative validation logic',
      'Dataset hash verification & metadata',
      'Relational database integration'
    ],
    skills: ['Prisma ORM', 'Supabase', 'PostgreSQL', 'SQLite', 'Python', 'SQL', 'Firebase']
  },
  {
    index: '04',
    title: 'Product Thinking',
    description: 'Structuring project requirements, workflows, and implementation paths.',
    details: [
      'Early-stage MVP planning & sizing',
      'Technical documentation & READMEs',
      'User flows and schema architecture'
    ],
    skills: ['Git & GitHub', 'Vercel', 'Technical Writing', 'PRD', 'Figma']
  }
];
---

<section id="capabilities" class="section-spacing relative bg-bg">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Section Header -->
    <div class="mb-16 md:mb-20 reveal">
      <p class="font-mono text-xs uppercase tracking-[0.25em] text-accent mb-3">/ COMPETENCE</p>
      <h2 class="text-4xl md:text-6xl font-bold tracking-tighter uppercase leading-[0.95] font-display text-text">
        CAPABILITIES
      </h2>
      <p class="text-base text-text-muted mt-4 max-w-2xl font-light">
        A structured list of engineering domains, methodologies, and technologies I apply to transform digital requirements into operational products.
      </p>
    </div>

    <!-- Capabilities Horizontal List -->
    <div class="border-y border-border/60 divide-y divide-border/60 reveal-stagger">
      {capabilities.map((cap) => (
        <div class="capabilities-row relative py-8 px-4 md:px-6 transition-all duration-300 hover:bg-surface/20 group">
          <!-- Subtle hover indicator line on the left -->
          <div class="absolute left-0 top-0 bottom-0 w-[2px] bg-transparent group-hover:bg-accent transition-all duration-300"></div>
          
          <div class="grid md:grid-cols-12 gap-6 items-start relative z-10">
            
            <!-- Index & Title (Left 4 cols) -->
            <div class="md:col-span-4 space-y-2">
              <div class="flex items-center gap-2.5">
                <span class="font-mono text-xs text-accent">{cap.index} /</span>
                <h3 class="text-lg font-semibold text-text group-hover:text-accent transition-colors duration-200">
                  {cap.title}
                </h3>
              </div>
              <p class="text-xs text-text-dim leading-relaxed font-light max-w-xs">
                {cap.description}
              </p>
            </div>

            <!-- Bullet Details (Center 4 cols) -->
            <div class="md:col-span-4">
              <ul class="space-y-1.5 text-xs text-text-muted">
                {cap.details.map((detail) => (
                  <li class="flex items-start gap-2">
                    <span class="text-accent/60 text-[7px] mt-1.5">◈</span>
                    <span>{detail}</span>
                  </li>
                ))}
              </ul>
            </div>

            <!-- Tech Stack (Right 4 cols - Scannable) -->
            <div class="md:col-span-4 space-y-3">
              <span class="font-mono text-[9px] uppercase tracking-wider text-text-dim block">Associated Stack:</span>
              <div class="flex flex-wrap gap-1.5">
                {cap.skills.map((skill) => (
                  <span class="font-mono text-[9px] text-text-muted bg-surface border border-border/60 rounded px-2.5 py-0.5 group-hover:border-accent/30 group-hover:text-text transition-all duration-200">
                    {skill}
                  </span>
                ))}
              </div>
            </div>

          </div>
        </div>
      ))}
    </div>
  </div>
</section>
