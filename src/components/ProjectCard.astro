---
import type { Project } from '../data/projects';

interface Props {
  project: Project;
  featured?: boolean;
}

const { project, featured = false } = Astro.props;

const statusColors: Record<string, string> = {
  'MVP': 'text-accent bg-accent/10 border-accent/20',
  'In Development': 'text-accent-secondary bg-accent-secondary/10 border-accent-secondary/20',
  'Academic': 'text-text-dim bg-text-dim/10 border-text-dim/20',
  'Collaboration': 'text-accent-secondary bg-accent-secondary/10 border-accent-secondary/20',
  'Internship Project': 'text-success bg-success/10 border-success/20',
  'Experiment': 'text-text-muted bg-text-muted/10 border-text-muted/20',
  'Production': 'text-success bg-success/10 border-success/20',
};

const statusClass = statusColors[project.status] || statusColors['MVP'];
---

{featured ? (
  <!-- Redesigned Featured Project Card (Editorial Showcase) -->
  <div class="editorial-card card-teal-glow border border-border/80 bg-surface/40 p-6 md:p-8 transition-all duration-400 group reveal col-span-2">
    <div class="grid md:grid-cols-12 gap-8 items-center">
      
      <!-- Text Description Content (7 cols) -->
      <div class="md:col-span-7 space-y-5">
        <div>
          <!-- Header metadata pills -->
          <div class="flex flex-wrap items-center gap-2 mb-3">
            <span class="font-mono text-[9px] uppercase tracking-wider text-accent bg-accent/5 border border-accent/15 rounded-full px-2.5 py-0.5">
              {project.category}
            </span>
            <span class:list={['font-mono text-[9px] uppercase tracking-wider border rounded-full px-2 py-0.5', statusClass]}>
              {project.status}
            </span>
          </div>
          
          <h3 class="text-2xl md:text-3xl font-bold tracking-tight text-text font-display group-hover:text-accent transition-colors duration-300">
            {project.title}
          </h3>
        </div>

        <!-- Description -->
        <p class="text-sm md:text-base text-text-muted leading-relaxed font-light">
          {project.description}
        </p>

        {project.whyItMatters && (
          <p class="text-xs text-text-dim leading-relaxed border-l-2 border-accent/30 pl-3 italic">
            {project.whyItMatters}
          </p>
        )}

        <!-- Tech Stack Tags -->
        <div class="flex flex-wrap gap-1.5 pt-1">
          {project.techStack.map((tech) => (
            <span class="font-mono text-[9px] text-text-dim bg-bg-alt border border-border/40 rounded px-2 py-0.5">
              {tech}
            </span>
          ))}
        </div>

        <!-- Action Links -->
        <div class="flex flex-wrap items-center gap-4 pt-3 border-t border-border/40">
          <a
            href={project.github}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 text-xs text-text-muted hover:text-accent transition-all duration-200"
          >
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
            </svg>
            View Repository
          </a>
          {project.demo && (
            <a
              href={project.demo}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-1.5 text-xs text-accent hover:text-accent/80 transition-all duration-200"
            >
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
              </svg>
              Live Demo
            </a>
          )}
        </div>
      </div>
      
      <!-- CSS Mockup Placeholder (5 cols) -->
      <div class="md:col-span-5 flex items-center justify-center p-2">
        {project.title === 'IMGN Concept Web Catalog' && (
          <div class="css-browser w-full max-w-[280px] aspect-[4/3] flex flex-col select-none">
            <div class="css-browser-bar">
              <div class="css-browser-dot"></div>
              <div class="css-browser-dot"></div>
              <div class="css-browser-dot"></div>
              <div class="css-browser-address">imgnconcept.com/catalog</div>
            </div>
            <div class="p-3 flex-1 flex flex-col justify-between bg-bg-alt text-[8px]">
              <div class="h-2 w-1/3 bg-border rounded"></div>
              <div class="grid grid-cols-2 gap-2 my-auto">
                <div class="border border-border/60 rounded-md p-1.5 bg-surface/50 space-y-1.5">
                  <div class="h-8 w-full bg-border-strong/60 rounded flex items-center justify-center text-[7px] text-text-dim">📷 Part A</div>
                  <div class="h-1.5 w-2/3 bg-border rounded"></div>
                </div>
                <div class="border border-border/60 rounded-md p-1.5 bg-surface/50 space-y-1.5">
                  <div class="h-8 w-full bg-border-strong/60 rounded flex items-center justify-center text-[7px] text-text-dim">📷 Part B</div>
                  <div class="h-1.5 w-1/2 bg-border rounded"></div>
                </div>
              </div>
              <div class="flex items-center justify-between border-t border-border/40 pt-1.5">
                <div class="h-1.5 w-1/4 bg-border rounded"></div>
                <div class="h-2.5 w-7 bg-success/10 border border-success/25 rounded-sm text-[5px] text-success text-center flex items-center justify-center">Active</div>
              </div>
            </div>
          </div>
        )}
        
        {project.title === 'StatProv' && (
          <div class="css-data-grid w-full max-w-[280px] aspect-[4/3] flex flex-col justify-between border border-border/80 bg-[#0c0d10] p-4 text-[8px] select-none">
            <div class="flex items-center justify-between border-b border-border/60 pb-2">
              <span class="text-text-muted font-mono uppercase tracking-wider">/ PROVENANCE MONITOR</span>
              <span class="text-accent font-mono font-medium">SHA-256 OK</span>
            </div>
            <div class="space-y-2 my-auto font-mono">
              <div class="flex items-center justify-between border-b border-border/30 pb-1">
                <span class="text-text-dim">dataset_integrity()</span>
                <span class="text-success">✓ VALID</span>
              </div>
              <div class="space-y-0.5 bg-bg-alt p-2 rounded border border-border/40 text-[7px] text-text-dim">
                <p>SRC: UNU-Yogya/Prov</p>
                <p>REF: 0x9B169F2C...</p>
                <p>VERIFIED: ADMIN_AUTH</p>
              </div>
            </div>
            <div class="flex justify-between items-center border-t border-border/60 pt-2 text-text-dim font-mono">
              <span>SYSTEM ACTIVE</span>
              <span>v1.0.0</span>
            </div>
          </div>
        )}

        {project.title === 'BioLearn' && (
          <div class="css-phone w-36 flex flex-col bg-bg-alt select-none">
            <div class="css-phone-notch"></div>
            <div class="p-2.5 flex-1 flex flex-col justify-between text-[8px]">
              <div class="flex items-center justify-between border-b border-border/60 pb-1">
                <span class="font-medium text-text">BioLearn Mobile</span>
                <span class="text-accent font-mono">MVP</span>
              </div>
              <div class="border border-border/80 rounded bg-bg aspect-video flex items-center justify-center my-2 relative group overflow-hidden">
                <div class="w-5 h-5 rounded-full bg-accent/10 border border-accent/30 flex items-center justify-center text-accent">▶</div>
                <div class="absolute bottom-1 left-1 right-1 h-1 bg-accent/20 rounded">
                  <div class="w-2/3 h-full bg-accent rounded"></div>
                </div>
              </div>
              <div class="space-y-1.5 flex-1 flex flex-col justify-center">
                <div class="h-1.5 w-3/4 bg-border rounded"></div>
                <div class="space-y-1 pt-1 font-mono text-[7px]">
                  <div class="flex items-center gap-1">
                    <span class="w-1.5 h-1.5 border border-accent/50 rounded-sm bg-accent/10 text-accent flex items-center justify-center text-[5px]">✓</span>
                    <span class="text-text-dim">Cell Organelles</span>
                  </div>
                  <div class="flex items-center gap-1">
                    <span class="w-1.5 h-1.5 border border-border/50 rounded-sm"></span>
                    <span class="text-text-dim">Genetics DNA</span>
                  </div>
                </div>
              </div>
            </div>
          </div>
        )}

        {project.title === 'MasjidFlow' && (
          <div class="css-phone w-36 flex flex-col bg-bg-alt select-none">
            <div class="css-phone-notch"></div>
            <div class="p-2.5 flex-1 flex flex-col justify-between text-[8px]">
              <div class="flex items-center justify-between border-b border-border/60 pb-1">
                <span class="font-medium text-text">MasjidFlow</span>
                <span class="text-success font-mono">ACTIVE</span>
              </div>
              <div class="space-y-2 flex-1 flex flex-col justify-center py-2">
                <div class="border border-border/85 rounded p-1 bg-surface/50 space-y-1">
                  <div class="flex justify-between items-center">
                    <span class="font-medium text-text">Friday Agenda</span>
                    <span class="text-[5px] text-success bg-success/10 border border-success/20 px-1 rounded-sm">Approved</span>
                  </div>
                  <div class="h-1 w-2/3 bg-border rounded"></div>
                </div>
                <div class="border border-border/85 rounded p-1 bg-surface/50 space-y-1">
                  <div class="flex justify-between items-center">
                    <span class="font-medium text-text">Youth Meetup</span>
                    <span class="text-[5px] text-accent bg-accent/10 border border-accent/20 px-1 rounded-sm">Pending</span>
                  </div>
                  <div class="h-1 w-1/2 bg-border rounded"></div>
                </div>
              </div>
              <div class="grid grid-cols-3 gap-1 text-center border-t border-border/60 pt-1 text-[6px] text-text-dim font-mono">
                <span class="text-accent">Flow</span>
                <span>Agenda</span>
                <span>Admin</span>
              </div>
            </div>
          </div>
        )}
      </div>
    </div>
  </div>
) : (
  <!-- Redesigned Compact Secondary Project Card (Grid Item) -->
  <div class="editorial-card card-blue-glow border border-border/60 bg-surface/20 p-5 flex flex-col justify-between transition-all duration-400 group reveal">
    <div class="space-y-4">
      <div class="flex items-start justify-between gap-3">
        <span class="font-mono text-[9px] uppercase tracking-wider text-text-dim bg-bg-alt border border-border/50 rounded-md px-2 py-0.5">
          {project.category}
        </span>
        <a
          href={project.github}
          target="_blank"
          rel="noopener noreferrer"
          class="text-text-dim hover:text-accent transition-colors duration-200 shrink-0"
          aria-label={`GitHub repository for ${project.title}`}
        >
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
          </svg>
        </a>
      </div>

      <div class="space-y-1.5">
        <h3 class="text-base font-medium text-text group-hover:text-accent-secondary transition-colors duration-300">
          {project.title}
        </h3>
        <p class="text-xs text-text-dim leading-relaxed line-clamp-2 font-light">
          {project.description}
        </p>
      </div>
    </div>

    <!-- Stack chips list -->
    <div class="flex flex-wrap gap-1.5 pt-4 mt-4 border-t border-border/40">
      {project.techStack.slice(0, 3).map((tech) => (
        <span class="font-mono text-[8px] text-text-dim bg-bg-alt border border-border/40 rounded px-1.5 py-0.5">
          {tech}
        </span>
      ))}
    </div>
  </div>
)}
