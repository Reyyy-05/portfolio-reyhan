---
import type { Project } from '../data/projects';

interface Props {
  project: Project;
  featured?: boolean;
}

const { project, featured = false } = Astro.props;

const statusColors: Record<string, string> = {
  'MVP': 'text-accent bg-accent/10 border-accent/20',
  'In Development': 'text-accent-secondary bg-accent-secondary/10 border-accent-secondary/20',
  'Academic': 'text-text-dim bg-text-dim/10 border-text-dim/20',
  'Collaboration': 'text-accent-secondary bg-accent-secondary/10 border-accent-secondary/20',
  'Internship Project': 'text-success bg-success/10 border-success/20',
  'Experiment': 'text-text-muted bg-text-muted/10 border-text-muted/20',
  'Production': 'text-success bg-success/10 border-success/20',
};

const typeIcons: Record<string, string> = {
  web: '◈',
  mobile: '◇',
  data: '◆',
  product: '○',
};

const statusClass = statusColors[project.status] || statusColors['MVP'];
---

{featured ? (
  <!-- Featured Card -->
  <div class="bg-surface border border-border rounded-xl p-6 md:p-8 transition-all duration-300 hover:border-border-strong hover:-translate-y-0.5 hover:shadow-[0_8px_30px_-10px_rgba(94,234,212,0.15)] group reveal">
    <!-- Header -->
    <div class="flex items-start justify-between gap-4 mb-4">
      <div>
        <div class="flex items-center gap-2 mb-2">
          <span class="font-mono text-xs uppercase tracking-wider text-accent bg-accent/10 border border-accent/20 rounded-full px-3 py-1">
            {project.category}
          </span>
          <span class:list={['font-mono text-[10px] uppercase tracking-wider border rounded-full px-2 py-0.5', statusClass]}>
            {project.status}
          </span>
        </div>
        <h3 class="text-xl md:text-2xl font-semibold tracking-tight text-text font-display group-hover:text-accent transition-colors duration-300">
          {project.title}
        </h3>
      </div>

      <!-- Abstract Visual Motif -->
      <div class="hidden sm:flex shrink-0 w-12 h-12 items-center justify-center bg-accent/5 border border-accent/10 rounded-lg text-accent text-lg">
        {typeIcons[project.type]}
      </div>
    </div>

    <!-- Description -->
    <p class="text-sm md:text-base text-text-muted leading-relaxed mb-3">
      {project.description}
    </p>

    {project.whyItMatters && (
      <p class="text-xs text-text-dim leading-relaxed mb-4 italic">
        → {project.whyItMatters}
      </p>
    )}

    <!-- Tech Stack -->
    <div class="flex flex-wrap gap-2 mb-5">
      {project.techStack.map((tech) => (
        <span class="font-mono text-[10px] text-text-dim bg-bg-alt border border-border/50 rounded-md px-2 py-1">
          {tech}
        </span>
      ))}
    </div>

    <!-- Actions -->
    <div class="flex items-center gap-3">
      <a
        href={project.github}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 text-sm text-text-muted hover:text-accent transition-colors"
      >
        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
          <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
        </svg>
        Source Code
      </a>
      {project.demo && (
        <a
          href={project.demo}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 text-sm text-accent hover:text-accent/80 transition-colors"
        >
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
          </svg>
          Live Demo
        </a>
      )}
    </div>
  </div>
) : (
  <!-- Compact Card -->
  <div class="bg-surface border border-border rounded-xl p-5 transition-all duration-300 hover:border-border-strong hover:-translate-y-0.5 hover:shadow-[0_4px_20px_-8px_rgba(94,234,212,0.1)] group reveal">
    <div class="flex items-start justify-between gap-3 mb-2">
      <div class="flex items-center gap-2">
        <span class="text-accent/60 text-sm">{typeIcons[project.type]}</span>
        <span class="font-mono text-[10px] uppercase tracking-wider text-text-dim">{project.category}</span>
      </div>
      <a
        href={project.github}
        target="_blank"
        rel="noopener noreferrer"
        class="text-text-dim hover:text-accent transition-colors shrink-0"
        aria-label={`GitHub repository for ${project.title}`}
      >
        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
          <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
        </svg>
      </a>
    </div>

    <h3 class="text-base font-medium text-text group-hover:text-accent transition-colors duration-300 mb-1.5">
      {project.title}
    </h3>

    <p class="text-xs text-text-dim leading-relaxed mb-3 line-clamp-2">
      {project.description}
    </p>

    <div class="flex flex-wrap gap-1.5">
      {project.techStack.slice(0, 4).map((tech) => (
        <span class="font-mono text-[9px] text-text-dim bg-bg-alt border border-border/50 rounded px-1.5 py-0.5">
          {tech}
        </span>
      ))}
    </div>
  </div>
)}
