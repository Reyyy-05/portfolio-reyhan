---
// Hero — Build Log style with Project Operating Board
const boardTiles = [
  {
    category: 'Web Systems',
    project: 'IMGN Concept Catalog',
    status: 'Production',
    statusColor: 'bg-success',
    meta: 'Next.js · Supabase',
    animClass: 'animate-float',
  },
  {
    category: 'Mobile Apps',
    project: 'BioLearn · MasjidFlow',
    status: 'MVP',
    statusColor: 'bg-accent',
    meta: 'Expo · TypeScript',
    animClass: 'animate-float-delayed',
  },
  {
    category: 'Data-Oriented Systems',
    project: 'StatProv',
    status: 'MVP',
    statusColor: 'bg-accent',
    meta: 'Prisma · SQLite · Hash',
    animClass: 'animate-float-slow',
  },
  {
    category: 'Product Experiments',
    project: 'Pupukku · SmartRoutine',
    status: 'Experiment',
    statusColor: 'bg-accent-secondary',
    meta: 'Firebase · Mobile',
    animClass: 'animate-float-delayed',
  },
];

const stats = [
  { label: 'Selected Projects', value: '10+' },
  { label: 'Web & Mobile', value: '—' },
  { label: 'Data Systems', value: '—' },
  { label: 'GitHub Portfolio', value: '→' },
];
---

<section class="relative min-h-screen flex items-center pt-20 pb-16 md:py-0 overflow-hidden">
  <!-- Subtle background gradient -->
  <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top_right,_rgba(94,234,212,0.04)_0%,_transparent_60%)]"></div>
  <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_bottom_left,_rgba(124,156,255,0.03)_0%,_transparent_60%)]"></div>

  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 w-full relative">
    <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">

      <!-- Left Column -->
      <div class="space-y-6">
        <!-- Eyebrow -->
        <p class="font-mono text-xs uppercase tracking-[0.2em] text-accent">
          // BUILD LOG — PORTFOLIO
        </p>

        <!-- Name -->
        <h1 class="text-4xl md:text-6xl font-semibold tracking-tight leading-[1.05] text-text font-display">
          Reyhan Albar<br />Fahryan
        </h1>

        <!-- Role Badge -->
        <div class="inline-flex items-center gap-2">
          <span class="w-2 h-2 rounded-full bg-success animate-pulse-dot"></span>
          <span class="font-mono text-xs uppercase tracking-wider text-text-muted">
            Informatics Student & Digital Product Builder
          </span>
        </div>

        <!-- Headline -->
        <p class="text-lg md:text-xl text-text-muted leading-relaxed max-w-lg">
          Building Web, Mobile, and Data-Oriented Digital Products.
        </p>

        <!-- Subheadline -->
        <p class="text-sm md:text-base text-text-dim leading-relaxed max-w-lg">
          Mahasiswa Informatika semester 6 yang berfokus pada full-stack web development,
          mobile app development, data-oriented systems, dan digital product prototyping.
        </p>

        <!-- CTAs -->
        <div class="flex flex-wrap items-center gap-3 pt-2">
          <a
            href="#work"
            id="cta-view-work"
            class="bg-accent text-bg font-medium px-5 py-2.5 rounded-lg hover:bg-accent/90 transition-colors text-sm"
          >
            View Work
          </a>
          <a
            href="/cv-reyhan.pdf"
            id="cta-resume"
            class="border border-border text-text px-5 py-2.5 rounded-lg hover:border-border-strong hover:bg-surface transition-colors text-sm"
          >
            Resume
          </a>
          <a
            href="https://github.com/Reyyy-05"
            target="_blank"
            rel="noopener noreferrer"
            id="cta-github"
            class="border border-border text-text-muted px-4 py-2.5 rounded-lg hover:border-border-strong hover:bg-surface hover:text-text transition-colors text-sm inline-flex items-center gap-2"
          >
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
            </svg>
            GitHub
          </a>
        </div>
      </div>

      <!-- Right Column — Project Operating Board -->
      <div class="relative hidden lg:block">
        <!-- Board Container -->
        <div class="relative space-y-3">
          <!-- Board Header -->
          <div class="flex items-center gap-2 mb-4">
            <span class="w-1.5 h-1.5 rounded-full bg-accent animate-pulse-dot"></span>
            <span class="font-mono text-xs text-text-dim uppercase tracking-wider">Project Operating Board</span>
          </div>

          <!-- Tiles -->
          {boardTiles.map((tile) => (
            <div
              class:list={[
                'bg-surface border border-border rounded-xl p-4 transition-all duration-300 hover:border-border-strong hover:-translate-y-0.5 hover:shadow-[0_8px_30px_-10px_rgba(94,234,212,0.12)] group',
                tile.animClass,
              ]}
            >
              <div class="flex items-start justify-between gap-3">
                <div class="flex-1 min-w-0">
                  <div class="flex items-center gap-2 mb-1.5">
                    <span class:list={['w-1.5 h-1.5 rounded-full animate-pulse-dot', tile.statusColor]}></span>
                    <span class="font-mono text-[10px] uppercase tracking-wider text-text-dim">{tile.category}</span>
                  </div>
                  <p class="text-sm text-text font-medium truncate">{tile.project}</p>
                </div>
                <div class="flex flex-col items-end gap-1 shrink-0">
                  <span class="font-mono text-[10px] uppercase tracking-wider text-accent/70 bg-accent/5 border border-accent/10 rounded-full px-2 py-0.5">
                    {tile.status}
                  </span>
                  <span class="font-mono text-[10px] text-text-dim">{tile.meta}</span>
                </div>
              </div>
            </div>
          ))}

          <!-- Stats Row -->
          <div class="grid grid-cols-4 gap-2 pt-2">
            {stats.map((stat) => (
              <div class="bg-surface/50 border border-border/50 rounded-lg p-2.5 text-center">
                <p class="font-mono text-xs text-accent font-medium">{stat.value}</p>
                <p class="font-mono text-[9px] text-text-dim uppercase tracking-wider mt-0.5">{stat.label}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
