---
import ProjectCard from './ProjectCard.astro';
import { featuredProjects, otherProjects } from '../data/projects';
---

<section id="work" class="section-spacing relative bg-bg">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Section Header -->
    <div class="mb-16 md:mb-20 reveal">
      <p class="font-mono text-xs uppercase tracking-[0.25em] text-accent mb-3">/ PORTFOLIO</p>
      <h2 class="text-4xl md:text-6xl font-bold tracking-tighter uppercase leading-[0.95] font-display text-text">
        SELECTED BUILDS
      </h2>
      <p class="text-base text-text-muted mt-4 max-w-2xl font-light">
        A selection of academic, personal, and collaborative projects demonstrating full-stack web architectures, mobile application logic, and data verification protocols.
      </p>
    </div>

    <!-- Featured Projects Grid (Stacked full-width cards) -->
    <div class="grid grid-cols-1 gap-8 mb-24 reveal-stagger">
      {featuredProjects.map((project) => (
        <ProjectCard project={project} featured={true} />
      ))}
    </div>

    <!-- Other Projects Grid (Compact cards) -->
    <div class="reveal mt-20">
      <div class="flex items-center gap-3 mb-10">
        <span class="font-mono text-xs uppercase tracking-[0.25em] text-text-dim">/ AUXILIARY BUILDS</span>
        <div class="flex-1 h-px bg-border/60"></div>
      </div>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 reveal-stagger">
      {otherProjects.map((project) => (
        <ProjectCard project={project} featured={false} />
      ))}
    </div>
  </div>
</section>
